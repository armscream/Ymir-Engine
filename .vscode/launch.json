    "version": "0.2.0",
    "configurations": [
        {
            "name": "Build Game (from game.json)",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}/build_from_game_config.ps1\""
        },
        {
            "name": "Build and Run Game (from game.json)",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}/run_from_game_config.ps1\""
        },
        {
            "name": "Build Editor",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"New-Item -ItemType Directory -Path 'Build' -Force | Out-Null; odin build Editor -out:Build/Editor.exe\""
        },
        {
            "name": "Build and Run Editor",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"New-Item -ItemType Directory -Path 'Build' -Force | Out-Null; odin build Editor -out:Build/Editor.exe; & './Build/Editor.exe'\""
        }
    ]
}